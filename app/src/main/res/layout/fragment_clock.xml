<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/screen_padding"
    android:background="?attr/colorSurface">

    <!-- Toggle button top-end -->
    <ImageButton
        android:id="@+id/btnToggleMode"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_clock"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/btn_toggle_clock_mode"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Timezone button top-start -->
    <ImageButton
        android:id="@+id/btnTimezone"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_timezone"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/btn_select_timezone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Analog clock -->
    <com.devomar.clock.clock.AnalogClockView
        android:id="@+id/analogClock"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/btnToggleMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toTopOf="@id/tvDate"
        app:layout_constraintVerticalBias="0.3"
        app:layout_constraintWidth_max="@dimen/analog_clock_max_size" />

    <!-- Digital clock (same position, visibility toggled) -->
    <TextView
        android:id="@+id/tvDigitalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/digital_clock_text_size"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="?attr/colorOnSurface"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/analogClock"
        app:layout_constraintBottom_toBottomOf="@id/analogClock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Date -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/date_text_size"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/analogClock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTimezone"
        app:layout_constraintVerticalChainStyle="packed" />

    <!-- Timezone label -->
    <TextView
        android:id="@+id/tvTimezone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/timezone_text_size"
        android:textColor="@color/textSecondary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
