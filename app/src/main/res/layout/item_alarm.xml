<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/item_horizontal_padding"
    android:paddingEnd="@dimen/item_horizontal_padding"
    android:paddingTop="@dimen/item_vertical_padding"
    android:paddingBottom="@dimen/item_vertical_padding"
    android:background="?attr/selectableItemBackground"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvAlarmTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="@dimen/alarm_time_text_size"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:fontFamily="monospace"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switchEnabled"
        app:layout_constraintBottom_toTopOf="@id/tvAlarmLabel" />

    <TextView
        android:id="@+id/tvAlarmLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="@dimen/alarm_label_text_size"
        android:textColor="@color/textSecondary"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAlarmTime"
        app:layout_constraintEnd_toStartOf="@id/switchEnabled"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchEnabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@id/btnDelete"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="8dp" />

    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="@dimen/icon_size"
        android:layout_height="@dimen/icon_size"
        android:src="@drawable/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/btn_delete_alarm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
